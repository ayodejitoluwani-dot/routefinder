# Map Provider Selection
# Options: 'google' or 'here'
# Choose which mapping service to use
MAPS_PROVIDER=google

# Google Maps API Configuration
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable the "Directions API" in your project
# Required if MAPS_PROVIDER=google
GOOGLE_MAPS_API_KEY=your_google_api_key_here

# HERE API Configuration
# Get your API key from: https://developer.here.com/
# Enable "Routing API" in your project
# Required if MAPS_PROVIDER=here
HERE_API_KEY=your_here_api_key_here

# Optional: Application settings
APP_ENV=development
DEBUG=False